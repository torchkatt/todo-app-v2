# ─── Firebase Config (públicas por diseño) ───
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# ─── Payments (Wompi) — SOLO la llave pública va al frontend ───
VITE_WOMPI_PUBLIC_KEY=pub_test_PENDIENTE

# ─── Observabilidad (opcional — vacío = Sentry deshabilitado) ───
VITE_SENTRY_DSN=

# NOTA: NO debe existir VITE_DEEPSEEK_API_KEY. La IA se sirve vía Cloud Function (aiProxy).
