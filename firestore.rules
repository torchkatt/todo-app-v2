rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ───────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'SUPER_ADMIN' ||
        request.auth.token.role == 'ADMIN'
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSellerOwner(sellerId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/sellers/$(sellerId)).data.ownerId == request.auth.uid;
    }

    function isValidUserData() {
      return request.resource.data.role in ['CUSTOMER', 'SELLER', 'COURIER', 'ADMIN', 'SUPER_ADMIN'];
    }

    function canCreateUser() {
      return (request.resource.data.uid == request.auth.uid || isOwner(request.resource.data.id)) &&
        request.resource.data.role == 'CUSTOMER';
    }

    function unchangedKeys(keys) {
      return request.resource.data.diff(resource.data).unchangedKeys().hasAll(keys);
    }

    // ─── USERS ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && canCreateUser()) || (isAdmin() && isValidUserData());
      allow update: if (isAdmin() && isValidUserData()) || (isOwner(userId) &&
        request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ─── CATEGORIES ────────────────────────────────────────────────────
    match /categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── SELLERS ───────────────────────────────────────────────────────
    match /sellers/{sellerId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // El dueño edita su perfil de tienda; stats/subscription/isVerified/rating solo
      // los mueve el backend (moderación, facturación, cálculo de reputación).
      allow update: if isAdmin() || (
        isSellerOwner(sellerId) &&
        unchangedKeys(['stats', 'subscription', 'isVerified', 'rating', 'ratingCount', 'ownerId', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    // ─── LISTINGS ──────────────────────────────────────────────────────
    match /listings/{listingId} {
      allow read: if true;
      // El vendedor no puede publicar ya "aprobado", destacado, ni fijar sus propias stats.
      allow create: if isAuthenticated() &&
        isSellerOwner(request.resource.data.sellerId) &&
        request.resource.data.isApproved == false &&
        request.resource.data.isFeatured == false &&
        request.resource.data.stats.views == 0 &&
        request.resource.data.stats.favorites == 0 &&
        request.resource.data.stats.transactions == 0;
      allow update: if isAdmin() || (
        isSellerOwner(resource.data.sellerId) &&
        unchangedKeys(['isApproved', 'isFeatured', 'stats', 'sellerId', 'createdAt'])
      );
      allow delete: if isAdmin() || isSellerOwner(resource.data.sellerId);
    }

    // ─── TRANSACTIONS ──────────────────────────────────────────────────
    // Toda la creación y confirmación de pago vive en Cloud Functions
    // (createTransaction / wompiWebhook) — el cliente nunca origina montos.
    match /transactions/{transactionId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.buyerId == request.auth.uid) ||
        (isAuthenticated() && isSellerOwner(resource.data.sellerId)) ||
        (isAuthenticated() && resource.data.courierId == request.auth.uid);
      allow create: if false;
      // El comprador solo puede cancelar mientras el pago está pendiente, y solo
      // puede tocar 'status' y 'updatedAt' — nunca montos ni datos de pago.
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.buyerId == request.auth.uid &&
         resource.data.status == 'PENDING_PAYMENT' &&
         request.resource.data.status == 'CANCELLED' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ─── ORDERS ────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── NOTIFICATIONS ─────────────────────────────────────────────────
    match /notifications/{doc} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // El usuario solo puede marcar como leída su propia notificación.
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ─── CHATS ─────────────────────────────────────────────────────────
    // El documento padre (participantes, último mensaje) solo lo escribe
    // el backend (Admin SDK) vía getOrCreateChat / onChatMessageCreate.
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // El remitente solo puede publicar mensajes propios, salvo la respuesta del
        // asistente IA en un hilo type=='ai' (el cliente la persiste porque el callable
        // aiChat solo devuelve texto — es un hilo privado usuario↔IA, sin otra parte
        // a la que un mensaje 'ai' falso pueda afectar).
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          (
            request.resource.data.senderId == request.auth.uid ||
            (request.resource.data.senderId == 'ai' &&
             get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'ai')
          ) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 && request.resource.data.text.size() < 4000;
        allow update, delete: if false;
      }

      match /reads/{uid} {
        allow read, write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ─── ANALYTICS ─────────────────────────────────────────────────────
    // Solo autenticados crean eventos. Solo admins leen/borran.
    match /analytics_events/{doc} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── FINANZAS / IA — SOLO BACKEND (Admin SDK) ─────────────────────
    match /processed_events/{doc} {
      allow read, write: if false;
    }
    match /rate_limits/{doc} {
      allow read, write: if false;
    }
    match /audit_logs/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /ai_usage/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }
    match /ai_strikes/{doc} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
