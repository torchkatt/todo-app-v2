rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth.token.role == 'SUPER_ADMIN';
    }
    match /sellers/{doc} {
      allow read: if true;
      allow write: if request.auth.uid == resource.data.ownerId || request.auth.token.role == 'SUPER_ADMIN';
    }
    match /listings/{doc} {
      allow read: if true;
      allow write: if request.auth.uid == get(/databases/$(database)/documents/sellers/$(resource.data.sellerId)).data.ownerId || request.auth.token.role == 'SUPER_ADMIN';
    }
    match /analytics_events/{doc} {
      allow write: if true;
      allow read: if request.auth.token.role == 'SUPER_ADMIN';
    }
    match /notifications/{doc} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if request.auth.uid == resource.data.userId || request.auth.token.role == 'SUPER_ADMIN';
    }
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
