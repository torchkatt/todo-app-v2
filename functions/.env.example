# Secretos de backend (Cloud Functions). Copiar a functions/.env para emuladores locales
# (gitignored) o definir vía `firebase functions:secrets:set <NOMBRE>` para deploy real.

# ─── Wompi (pendiente hasta obtener credenciales reales) ───
WOMPI_PRIVATE_KEY=prv_test_PENDIENTE
WOMPI_EVENTS_SECRET=PENDIENTE
WOMPI_INTEGRITY_SECRET=PENDIENTE
WOMPI_ENV=test

# ─── DeepSeek (proxy de IA) ───
DEEPSEEK_API_KEY=PENDIENTE
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=1000

# ─── Reglas de negocio ───
PLATFORM_FEE_BPS=500
IVA_BPS=1900
EMAIL_ENABLED=false

# ─── Observabilidad (opcional — sin DSN, captureError queda como no-op) ───
SENTRY_DSN=
